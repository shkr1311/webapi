{
	"info": {
		"_postman_id": "cod-microservices-collection",
		"name": "COD Microservices API",
		"description": "Complete API collection for Cash On Delivery Microservices POC",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "product_url", "value": "http://localhost:5001" },
		{ "key": "employee_url", "value": "http://localhost:5002" },
		{ "key": "order_url", "value": "http://localhost:5003" },
		{ "key": "token", "value": "" }
	],
	"item": [
		{
			"name": "🔐 Authentication",
			"item": [
				{
					"name": "Get JWT Token (Product Service)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token saved!');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
						},
						"url": { "raw": "{{product_url}}/api/auth/token" }
					}
				},
				{
					"name": "Get JWT Token (Order Service)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token saved!');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
						},
						"url": { "raw": "{{order_url}}/api/auth/token" }
					}
				}
			]
		},
		{
			"name": "📦 Product Service",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": { "raw": "{{product_url}}/health" }
					}
				},
				{
					"name": "Add Product",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"iPhone 15 Pro\",\n  \"price\": 999.99,\n  \"stock\": 50\n}"
						},
						"url": { "raw": "{{product_url}}/api/products" }
					}
				},
				{
					"name": "Add Product - Samsung Galaxy",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Samsung Galaxy S24\",\n  \"price\": 799.99,\n  \"stock\": 100\n}"
						},
						"url": { "raw": "{{product_url}}/api/products" }
					}
				},
				{
					"name": "Get All Products",
					"request": {
						"method": "GET",
						"url": { "raw": "{{product_url}}/api/products" }
					}
				},
				{
					"name": "Get Product by ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{product_url}}/api/products/1" }
					}
				},
				{
					"name": "Update Product",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"iPhone 15 Pro Max\",\n  \"price\": 1199.99\n}"
						},
						"url": { "raw": "{{product_url}}/api/products/1" }
					}
				},
				{
					"name": "Delete Product",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{product_url}}/api/products/1" }
					}
				}
			]
		},
		{
			"name": "👷 Employee Service",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": { "raw": "{{employee_url}}/health" }
					}
				},
				{
					"name": "Add Employee - Rahul",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Rahul Sharma\",\n  \"phone\": \"+91-9876543210\"\n}"
						},
						"url": { "raw": "{{employee_url}}/api/employees" }
					}
				},
				{
					"name": "Add Employee - Priya",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Priya Singh\",\n  \"phone\": \"+91-9876543211\"\n}"
						},
						"url": { "raw": "{{employee_url}}/api/employees" }
					}
				},
				{
					"name": "Get All Employees",
					"request": {
						"method": "GET",
						"url": { "raw": "{{employee_url}}/api/employees" }
					}
				},
				{
					"name": "Get Employee by ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{employee_url}}/api/employees/1" }
					}
				},
				{
					"name": "Get Available Employee",
					"request": {
						"method": "GET",
						"url": { "raw": "{{employee_url}}/api/employees/available" }
					}
				},
				{
					"name": "Update Availability",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"isAvailable\": false\n}"
						},
						"url": { "raw": "{{employee_url}}/api/employees/1/availability" }
					}
				}
			]
		},
		{
			"name": "🛒 Order Service",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": { "raw": "{{order_url}}/health" }
					}
				},
				{
					"name": "Create Order",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}"
						},
						"url": { "raw": "{{order_url}}/api/orders" }
					}
				},
				{
					"name": "Get All Orders",
					"request": {
						"method": "GET",
						"url": { "raw": "{{order_url}}/api/orders" }
					}
				},
				{
					"name": "Get Order by ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{order_url}}/api/orders/1" }
					}
				},
				{
					"name": "Mark Order Delivered",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{order_url}}/api/orders/1/deliver" }
					}
				},
				{
					"name": "Mark COD Payment Paid",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{order_url}}/api/orders/1/pay" }
					}
				}
			]
		},
		{
			"name": "🔄 Full COD Flow (Run in Order)",
			"item": [
				{
					"name": "1. Get Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
						},
						"url": { "raw": "{{product_url}}/api/auth/token" }
					}
				},
				{
					"name": "2. Create Product",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"MacBook Pro M3\",\n  \"price\": 2499.99,\n  \"stock\": 25\n}"
						},
						"url": { "raw": "{{product_url}}/api/products" }
					}
				},
				{
					"name": "3. Create Employee",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Amit Kumar\",\n  \"phone\": \"+91-9988776655\"\n}"
						},
						"url": { "raw": "{{employee_url}}/api/employees" }
					}
				},
				{
					"name": "4. Create Order (Auto-validates & assigns)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": 1,\n  \"quantity\": 1\n}"
						},
						"url": { "raw": "{{order_url}}/api/orders" }
					}
				},
				{
					"name": "5. Mark Delivered",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{order_url}}/api/orders/1/deliver" }
					}
				},
				{
					"name": "6. Mark COD Paid",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{order_url}}/api/orders/1/pay" }
					}
				}
			]
		}
	]
}
